# Postiz Self-Hosted Configuration
# Copy this file to .env and update the values

# ======================
# Database Configuration
# ======================
POSTGRES_PASSWORD=postiz_secure_password_change_me

# ======================
# Redis Configuration
# ======================
REDIS_PASSWORD=redis_secure_password_change_me

# ======================
# Application Configuration
# ======================

# Base URL - Change this for production (e.g., https://postiz.yourdomain.com)
POSTIZ_URL=http://localhost:3000

# Port to run Postiz on
POSTIZ_PORT=3000

# JWT Secret - Generate a random string (32+ characters)
# PowerShell: -join ((65..90) + (97..122) + (48..57) | Get-Random -Count 32 | ForEach-Object {[char]$_})
JWT_SECRET=change_this_to_random_string_in_production

# Session Secret - Generate a random string (32+ characters)
SESSION_SECRET=change_this_to_random_string_in_production

# ======================
# API Configuration
# ======================

# Rate limit per minute per IP
API_RATE_LIMIT=100

# ======================
# Logging
# ======================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ======================
# Production Settings (Optional)
# ======================

# Uncomment and configure for production deployment

# Enable HTTPS (requires reverse proxy like nginx)
# POSTIZ_SECURE_COOKIES=true

# SMTP for email notifications (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# Sentry for error tracking (optional)
# SENTRY_DSN=your-sentry-dsn

# ======================
# Social Platform OAuth (Configure in Postiz UI)
# ======================

# These are configured through the Postiz web interface
# after deployment. You'll need to create apps on each platform:
#
# LinkedIn: https://www.linkedin.com/developers/apps
# X (Twitter): https://developer.twitter.com/en/portal/dashboard
# Instagram: https://developers.facebook.com/apps
#
# Callback URLs will be:
# - LinkedIn: {POSTIZ_URL}/api/auth/linkedin/callback
# - X: {POSTIZ_URL}/api/auth/twitter/callback
# - Instagram: {POSTIZ_URL}/api/auth/instagram/callback
