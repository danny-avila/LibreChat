# Copy to deploy/ferretdb/.env and replace every secret before first boot.
# Prefer URL-safe random values for database passwords because they are embedded in URIs.

LIBRECHAT_ENV_FILE=./deploy/ferretdb/.env
LIBRECHAT_YAML_PATH=./librechat.yaml
LIBRECHAT_BIND_ADDRESS=127.0.0.1
LIBRECHAT_HTTP_PORT=3080
LIBRECHAT_API_IMAGE=librechat-api:ferretdb

OBJECT_STORE_MODE=minio
RAG_ENABLED=false

# Use deploy/ferretdb/images.linux-amd64.env as the starting point for
# production image pins, then update those pins deliberately for upgrades.
GATEWAY_IMAGE=nginx:1.27.0-alpine
DOCUMENTDB_IMAGE=ghcr.io/ferretdb/postgres-documentdb:17-0.107.0-ferretdb-2.7.0
FERRETDB_IMAGE=ghcr.io/ferretdb/ferretdb:2.7.0
VALKEY_IMAGE=valkey/valkey:8.1-alpine
MEILI_IMAGE=getmeili/meilisearch:v1.35.1
SEAWEEDFS_IMAGE=chrislusf/seaweedfs:latest

NODE_MAX_OLD_SPACE_SIZE=6144
DOMAIN_CLIENT=https://chat.example.com
DOMAIN_SERVER=https://chat.example.com
TRUST_PROXY=1
HOST=0.0.0.0
PORT=3080
NODE_ENV=production
CONSOLE_JSON=true
DEBUG_LOGGING=false
DEBUG_CONSOLE=false
NO_INDEX=false

DOCUMENTDB_USER=ferretdb
DOCUMENTDB_PASSWORD=change-me-documentdb-url-safe
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=5
MONGO_AUTO_INDEX=true
FERRETDB_TELEMETRY=disable

# LibreChat still uses REDIS_* variable names and a redis:// URI, but the
# compose service runs Valkey to avoid Redis 7.4+ RSALv2/SSPLv1 licensing.
REDIS_PASSWORD=change-me-valkey
REDIS_KEY_PREFIX=librechat

MEILI_MASTER_KEY=change-me-meili-master-key

# MinIO is AGPLv3/commercial dual licensed. Use a commercial license or replace
# this service with another S3-compatible endpoint if AGPL is outside policy.
MINIO_IMAGE=quay.io/minio/minio:RELEASE.2025-09-07T16-13-09Z-cpuv1
MINIO_MC_IMAGE=quay.io/minio/mc:RELEASE.2025-08-13T08-35-41Z-cpuv1
MINIO_ROOT_USER=librechat-minio
MINIO_ROOT_PASSWORD=change-me-minio-root-password
MINIO_BUCKET=librechat
AWS_REGION=us-east-1

# Optional RAG. The default commercial stack leaves this disabled so the
# unresolved external RAG image is not part of the runtime. To enable RAG, set
# RAG_ENABLED=true, include deploy-compose.ferretdb.rag.yml in COMPOSE_FILES,
# and complete the source/license review fields below.
RAG_PORT=8000
PGVECTOR_IMAGE=pgvector/pgvector:0.8.0-pg15-trixie
RAG_API_IMAGE=registry.librechat.ai/danny-avila/librechat-rag-api-dev-lite@sha256:643294ce339cdcdcc297acbb0cfa513310e5e7ed1544c86cf8059a64f39615c4
RAG_POSTGRES_DB=rag
RAG_POSTGRES_USER=rag
RAG_POSTGRES_PASSWORD=change-me-rag-postgres
RAG_API_SOURCE_URL=
RAG_API_SOURCE_REF=
RAG_API_SOURCE_LICENSE=
RAG_API_LICENSE_REVIEWED=false

JWT_SECRET=change-me-64-hex-jwt-secret
JWT_REFRESH_SECRET=change-me-64-hex-jwt-refresh-secret
CREDS_KEY=change-me-64-hex-creds-key
CREDS_IV=change-me-32-hex-creds-iv

ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=false
ALLOW_SOCIAL_LOGIN=false

# Add provider credentials here, for example:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_KEY=
