# Merge into deploy/ferretdb/.env only after RAG source/license/provenance
# review is complete. Also append deploy-compose.ferretdb.rag.yml to
# COMPOSE_FILES after the selected object-store override.

RAG_ENABLED=true
COMPOSE_FILES=deploy-compose.ferretdb.yml,deploy-compose.ferretdb.seaweedfs.yml,deploy-compose.ferretdb.rag.yml

RAG_PORT=8000
PGVECTOR_IMAGE=pgvector/pgvector@sha256:8809cfffff0082cf260c9ac752f1dd1afc77f6f0a55c4e6411321e78efc3d9a5
RAG_API_IMAGE=registry.librechat.ai/danny-avila/librechat-rag-api-dev-lite@sha256:643294ce339cdcdcc297acbb0cfa513310e5e7ed1544c86cf8059a64f39615c4
RAG_POSTGRES_DB=rag
RAG_POSTGRES_USER=rag
RAG_POSTGRES_PASSWORD=change-me-rag-postgres

# Required by deploy/ferretdb/bin/validate-env.sh when RAG_ENABLED=true.
RAG_API_SOURCE_URL=https://github.com/danny-avila/LibreChat
RAG_API_SOURCE_REF=replace-with-reviewed-commit-or-tag
RAG_API_SOURCE_LICENSE=replace-with-reviewed-license-expression
RAG_API_LICENSE_REVIEWED=false
