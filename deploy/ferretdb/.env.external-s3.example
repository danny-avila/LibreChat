# Add these variables to deploy/ferretdb/.env when using
# deploy-compose.ferretdb.external-s3.yml.
#
# The S3-compatible service must create this bucket before LibreChat starts,
# or your provider must allow the configured credentials to create it.

OBJECT_STORE_MODE=external-s3
AWS_ENDPOINT_URL=http://s3.internal.example:8333
AWS_ACCESS_KEY_ID=change-me-s3-access-key
AWS_SECRET_ACCESS_KEY=change-me-s3-secret-key
AWS_BUCKET_NAME=librechat
AWS_REGION=us-east-1
AWS_FORCE_PATH_STYLE=true
