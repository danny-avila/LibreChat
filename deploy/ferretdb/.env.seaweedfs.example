# Add these variables to deploy/ferretdb/.env when using
# deploy-compose.ferretdb.seaweedfs.yml.
#
# SeaweedFS is Apache-2.0 and is used here as the S3-compatible object store.

OBJECT_STORE_MODE=seaweedfs
SEAWEEDFS_IMAGE=chrislusf/seaweedfs:latest
SEAWEEDFS_ACCESS_KEY=change-me-seaweedfs-access-key
SEAWEEDFS_SECRET_KEY=change-me-seaweedfs-secret-key
SEAWEEDFS_BUCKET=librechat
SEAWEEDFS_VOLUME_SIZE_LIMIT_MB=30000
SEAWEEDFS_VOLUME_MAX=100
