# Copy to deploy/ferretdb/.env.backup-shipping and set the rclone target.
# Prefer an rclone crypt remote or an encrypted destination bucket.

BACKUP_REMOTE=backup-crypt:librechat/ferretdb
BACKUP_SHIP_MODE=copy
BACKUP_SHIP_DRY_RUN=false
BACKUP_SHIP_TRANSFERS=4
BACKUP_SHIP_CHECKERS=8

# Optional when the service should use a dedicated rclone config file.
# RCLONE_CONFIG=/etc/librechat/rclone.conf
