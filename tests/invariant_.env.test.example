import fs from 'fs';
import path from 'path';

describe("Production secrets must not be hardcoded in .env.example", () => {
  const payloads = [
    // Exact exploit case: actual cryptographic secret from vulnerable snippet
    'CREDS_KEY=f34be427ebb29de8d88c107a71546019685ed8b241d8f2ed00c3df97ad2566f0',
    // Boundary case: another actual secret from the file
    'CREDS_IV=e2341419ec3dd3d19b13a1a87fafcbfb',
    // Valid input: placeholder pattern that should be used instead
    'CREDS_KEY=__CHANGE_ME_TO_RANDOM_HEX_64_CHARS__'
  ];

  test.each(payloads)("detects hardcoded secret: %s", (payload) => {
    const envExamplePath = path.join(__dirname, '..', '.env.example');
    const fileContent = fs.readFileSync(envExamplePath, 'utf-8');
    
    // Security property: No line in .env.example should contain actual cryptographic secrets
    // If a line matches an actual secret payload, the property is violated
    const lines = fileContent.split('\n');
    const secretLines = lines.filter(line => 
      line.trim() === payload && 
      !line.includes('__CHANGE_ME__') &&
      !line.includes('placeholder')
    );
    
    // The property holds if no lines contain actual hardcoded secrets
    expect(secretLines).toHaveLength(0);
  });
});