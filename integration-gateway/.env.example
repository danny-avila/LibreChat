# Docker Compose from this folder: LibreChat api host port (must not be 8090).
PORT=3080
INTEGRATION_GATEWAY_PORT=8090

# Gateway listen port (local node; Docker sets PORT=8090 in compose override)
GATEWAY_PORT=8090
DATA_DIR=./data

# LibreChat (Docker Compose service name is "api")
LC_BASE_URL=http://api:3080
LC_DEFAULT_AGENT_ID=replace-with-your-agent-id

# Encrypt stored LC passwords and API keys (32+ chars recommended)
ENCRYPTION_KEY=change-me-to-a-long-random-string-at-least-32-chars

# Demo integration client (seeded on first start if no clients exist)
DEMO_CLIENT_ID=demo_app
DEMO_CLIENT_SECRET=demo_secret_change_me

# Admin API (Phase 1 — see README「扩展方案」)
GATEWAY_ADMIN_TOKEN=dev-admin-token-change-me
ADMIN_RATE_LIMIT_RPM=120

# LibreChat must also have:
#   ALLOW_REGISTRATION=true
#   librechat.integration.yaml mounted with remoteAgents + allowedDomains
