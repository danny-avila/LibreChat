#=====================================================================#
#                       Bizu Chat Configuration                       #
#=====================================================================#

#==================================================#
#               Server Configuration               #
#==================================================#

HOST=localhost
PORT=3080

MONGO_URI=mongodb://127.0.0.1:27017/BizuChat

DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080

NO_INDEX=true
TRUST_PROXY=1

#===============#
# Debug Logging #
#===============#

# Set to true only for development — disable in production to prevent info leakage
DEBUG_LOGGING=false
DEBUG_CONSOLE=false
CONSOLE_JSON=false

#===================================================#
#                     Endpoints                     #
#===================================================#

# >>> REQUIRED: Get your key at https://openrouter.ai/keys <<<
OPENROUTER_KEY=

# Disable built-in endpoints (we use OpenRouter only)
OPENAI_API_KEY=
GOOGLE_KEY=
ANTHROPIC_API_KEY=
ASSISTANTS_API_KEY=

#============#
# Plugins    #
#============#

DEBUG_PLUGINS=false

# Generate your own with: openssl rand -hex 32
CREDS_KEY=
CREDS_IV=

#==================================================#
#                      Search                      #
#==================================================#

# Set to true + configure MeiliSearch if you want conversation search
SEARCH=false

#===================================================#
#                    User System                    #
#===================================================#

#========================#
# Moderation             #
#========================#

OPENAI_MODERATION=false
BAN_VIOLATIONS=true
BAN_DURATION=1000 * 60 * 60 * 2
BAN_INTERVAL=20

LOGIN_VIOLATION_SCORE=1
REGISTRATION_VIOLATION_SCORE=1
CONCURRENT_VIOLATION_SCORE=1
MESSAGE_VIOLATION_SCORE=1
NON_BROWSER_VIOLATION_SCORE=20

LOGIN_MAX=7
LOGIN_WINDOW=5
# Tighter registration limits to prevent account abuse
REGISTER_MAX=3
REGISTER_WINDOW=120

LIMIT_CONCURRENT_MESSAGES=true
CONCURRENT_MESSAGE_MAX=2

LIMIT_MESSAGE_IP=true
MESSAGE_IP_MAX=40
MESSAGE_IP_WINDOW=1

LIMIT_MESSAGE_USER=false
MESSAGE_USER_MAX=40
MESSAGE_USER_WINDOW=1

#========================#
# Balance                #
#========================#

CHECK_BALANCE=true

#========================#
# Registration and Login #
#========================#

ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false
ALLOW_PASSWORD_RESET=false
# Set to false and configure EMAIL_* below to require email verification
ALLOW_UNVERIFIED_EMAIL_LOGIN=false

SESSION_EXPIRY=1000 * 60 * 15
REFRESH_TOKEN_EXPIRY=(1000 * 60 * 60 * 24) * 7

# Generate your own with: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=

#========================#
# Shared Links           #
#========================#

ALLOW_SHARED_LINKS=true
# Require authentication to view shared links (prevents public data exposure)
ALLOW_SHARED_LINKS_PUBLIC=false

#===================================================#
#                        UI                         #
#===================================================#

APP_TITLE=Bizu
HELP_AND_FAQ_URL=https://bizu.chat/ajuda
CUSTOM_FOOTER=[Bizu](https://bizu.chat) - Seu assistente de IA.
