# =============================================================================
# .env.production.example — SMB-Team v0 manual VM deployment template
# =============================================================================
# This is a *delta* template: it contains ONLY the variables that we actually
# customized from upstream defaults in our first production deployment on GCP.
#
# For the full set of available LibreChat env vars (including all the optional
# integrations we did NOT enable — Azure AI Search, OAuth providers, email,
# Firebase, AWS S3, etc.), see the upstream template at the repo root:
#   .env.example
#
# To deploy:
#   1. Copy this file to .env  (NEVER commit .env)
#       cp .env.production.example .env
#   2. Fill in every <placeholder> below.
#   3. Generate fresh secrets with the commands shown in the comments.
#   4. docker compose up -d
#
# Secret hygiene: do NOT reuse the example secrets shipped in upstream
# .env.example — they are publicly known and unsafe for production.
# =============================================================================


#==================================================#
#               Server Configuration               #
#==================================================#

# Bind address. 0.0.0.0 makes the server reachable from outside the container.
HOST=0.0.0.0


#==================================================#
#                     Domains                      #
#==================================================#

# Public-facing URLs for the client and server. In our v0 deployment these are
# the same value (single-VM, no separate API host). Use https:// in production.
DOMAIN_CLIENT=<your-public-url-eg-https://chat.example.com>
DOMAIN_SERVER=<your-public-url-eg-https://chat.example.com>


#==================================================#
#                    Endpoints                     #
#==================================================#

# Anthropic API key for Claude models.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=<your-anthropic-api-key>


#==================================================#
#           Credentials Encryption (AES)           #
#==================================================#

# Used to encrypt user-supplied API keys at rest.
# Generate fresh values — DO NOT reuse the upstream example values.
#   CREDS_KEY:  openssl rand -hex 32   (64 hex chars)
#   CREDS_IV:   openssl rand -hex 16   (32 hex chars)
CREDS_KEY=<generate-with-openssl-rand-hex-32>
CREDS_IV=<generate-with-openssl-rand-hex-16>


#==================================================#
#                Meilisearch (search)              #
#==================================================#

# Master key for the bundled Meilisearch instance.
# Generate: openssl rand -hex 32
MEILI_MASTER_KEY=<generate-with-openssl-rand-hex-32>


#==================================================#
#              Registration / Auth                 #
#==================================================#

# Allow new users to register via the web UI.
# We set this to false in production to keep the instance internal-only.
# Flip to true temporarily when onboarding new teammates, then back to false.
ALLOW_REGISTRATION=false


#==================================================#
#                  JWT Secrets                     #
#==================================================#

# Secrets used to sign access and refresh tokens.
# Generate fresh values — DO NOT reuse the upstream example values.
#   openssl rand -hex 32
JWT_SECRET=<generate-with-openssl-rand-hex-32>
JWT_REFRESH_SECRET=<generate-with-openssl-rand-hex-32>
