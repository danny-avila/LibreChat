    {
      "parameters": {
        "jsCode": "// Ambil data input dari Webhook\nconst inputBody = $(\"Webhook Update\").first().json.body;\n\n// Cek apakah ada request ganti manager?\nif (inputBody.managerId) {\n  return [ { json: { lookupManager: true, ...inputBody } } ];\n} else {\n  return [ { json: { lookupManager: false, ...inputBody } } ];\n}"
      },
      "id": "26df2533-4c94-4a97-923d-a33a8e39120c",
