        "mongoDb": {
          "id": "HC6Gjp2c6DcejmqQ",
          "name": "MongoDB account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Data Input (Project Data)\nconst projectData = $(\"Need Manager Lookup?\").first().json;\n\n// Data Manager (Hasil Lookup)\nconst managerData = $json.username ? $json : {};\nconst managerName = managerData.username || managerData.name || undefined;\n\n// Gabungkan\nconst finalData = {\n  ...projectData,\n};\n\nif (managerName) {\n  finalData.managerName = managerName;\n}\n\n// Format Angka & Tanggal\nfinalData.updatedAt = new Date().toISOString();\nif (finalData.progress !== undefined) finalData.progress = parseInt(finalData.progress);\nif (finalData.budget !== undefined) finalData.budget = parseInt(finalData.budget);\nif (finalData.spent !== undefined) finalData.spent = parseInt(finalData.spent);\n\n// Hapus field yang TIDAK BOLEH di-update atau field sampah\ndelete finalData.lookupManager;\ndelete finalData._id; // PENTING: Jangan update _id\n// Kita sisakan 'projectId' agar bisa dibaca oleh node selanjutnya sebagai KEY, \n// tapi nanti di Mongo node kita pilih field apa saja yang mau di-update selain ini.\n\nreturn { \n  json: finalData \n};"
      },
      "id": "72f9efd8-0e20-489d-9c97-8158a41c5a64",
      "name": "Prep Complex Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        784,
        176
      ]
    },
    {
      "parameters": {
        "jsCode": "const projectData = $json;\n\nconst finalData = {\n  ...projectData,\n  updatedAt: new Date().toISOString()\n};\n\n// Format Angka\nif (finalData.progress !== undefined) finalData.progress = parseInt(finalData.progress);\nif (finalData.budget !== undefined) finalData.budget = parseInt(finalData.budget);\nif (finalData.spent !== undefined) finalData.spent = parseInt(finalData.spent);\n\n// Hapus field sampah\ndelete finalData.lookupManager;\ndelete finalData._id; // PENTING\n\nreturn { \n  json: finalData \n};"
      },
