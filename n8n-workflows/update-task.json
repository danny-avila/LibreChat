    {
      "parameters": {
        "jsCode": "const inputData = $(\"User Changed?\").first().json;\nconst userData = $json.email ? $json : {};\n\nconst userEmail = userData.email || 'unknown@system.local';\nconst userName = userData.name || userData.username || 'Unknown User';\n\nconst updateData = {\n  ...inputData,\n  assignedEmail: userEmail,\n  assignedName: userName,\n  updatedAt: new Date().toISOString()\n};\n\n// PENTING: Gunakan _id agar cocok dengan MongoDB\nconst cleanData = {\n  _id: inputData.taskId,\n  ...updateData\n};\n\n// Hapus field sampah\ndelete cleanData.taskId;\ndelete cleanData.lookupUser;\n\nreturn { json: cleanData };"
      },
