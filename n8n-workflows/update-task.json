        "jsCode": "const inputData = $json;\nconst updateData = { ...inputData };\n\nupdateData.updatedAt = new Date().toISOString();\n\n// PENTING: Gunakan _id agar cocok dengan MongoDB\nconst cleanData = {\n  _id: inputData.taskId,\n  ...updateData\n};\n\n// Hapus field sampah\ndelete cleanData.taskId;\ndelete cleanData.lookupUser;\n\nreturn { json: cleanData };"
      },
