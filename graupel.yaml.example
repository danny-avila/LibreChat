# Graupel Configuration
# Copy this file to `librechat.yaml` (or set CONFIG_PATH) and adjust values.
#
# 上游统一走 gptsapi.net(OpenAI 兼容中转,单 ${GPTSAPI_KEY}):
# - 内置 openAI / anthropic 端点通过 .env 的 OPENAI_REVERSE_PROXY / ANTHROPIC_REVERSE_PROXY
#   指向 gptsapi(gptsapi 兼容 OpenAI Chat Completions 与 Anthropic Messages 原生协议)。
# - 内置 google 端点禁用(.env GOOGLE_KEY 留空,gptsapi 不支持 Google GenAI 原生协议),
#   改用下方 name='Google' 的 custom 端点经 gptsapi 的 OpenAI 兼容接口托管 Gemini。
# - Grok / DeepSeek / GLM / Kimi / MiniMax 同样用 custom 端点经 gptsapi 托管。
# 模型选择器由 modelSpecs 策展(enforce 锁定,只显策展卡)。

version: 1.3.11

cache: true

# File storage: use S3-compatible (Cloudflare R2)
fileStrategy: "s3"

interface:
  endpointsMenu: false
  modelSelect: false
  parameters: true
  presets: false

memory:
  disabled: false
  personalize: true
  messageWindowSize: 5
  agent:
    enabled: true
    provider: "openAI"               # routed to gptsapi via OPENAI_REVERSE_PROXY
    model: "gemini-2.5-flash-lite"
    instructions: >
      Extract durable facts about the user worth remembering across chats:
      stated preferences (response format, tone, length), working context
      (languages, frameworks, projects, role), and stable personal facts.
      Do NOT store secrets, passwords, API keys, health, or financial details.
      Update/replace existing keys rather than duplicating.

registration:
  socialLogins:
    - google
    - github

endpoints:
  # OpenAI — GPT-5 family（经 .env OPENAI_REVERSE_PROXY 路由到 gptsapi）
  openAI:
    titleConvo: true
    titleModel: "gemini-2.5-flash-lite"   # 便宜模型做标题（经 gptsapi 可达）
    summarize: true
    summaryModel: "gemini-2.5-flash-lite"

  # Anthropic — Claude family（经 .env ANTHROPIC_REVERSE_PROXY 路由到 gptsapi）
  anthropic:
    titleConvo: true
    titleModel: "gemini-2.5-flash-lite"
    summarize: true
    summaryModel: "gemini-2.5-flash-lite"

  # Custom endpoints — 全部经 gptsapi（OpenAI 兼容），单 ${GPTSAPI_KEY}
  custom:
    # Google — Gemini family
    - name: "Gemini"
      apiKey: "${GPTSAPI_KEY}"
      baseURL: "https://api.gptsapi.net/v1"
      models:
        default:
          - "gemini-3.1-pro-preview"
          - "gemini-3-flash-preview"
          - "gemini-2.5-flash"
          - "gemini-2.5-flash-lite"
        fetch: false
      titleConvo: true
      titleModel: "gemini-2.5-flash-lite"
      modelDisplayLabel: "Gemini"
      iconURL: "google"
      dropParams: ["stop"]

    # Anthropic — Claude family (OpenAI-compatible via gptsapi; native Messages API path 404s through the relay)
    - name: "Claude"
      apiKey: "${GPTSAPI_KEY}"
      baseURL: "https://api.gptsapi.net/v1"
      models:
        default:
          - "claude-opus-4-8"
          - "claude-opus-4-7"
          - "claude-opus-4-6"
          - "claude-opus-4-5-20251101"
          - "claude-sonnet-4-6"
          - "claude-sonnet-4-6-thinking"
          - "claude-haiku-4-5-20251001"
        fetch: false
      titleConvo: true
      titleModel: "gemini-2.5-flash-lite"
      modelDisplayLabel: "Claude"
      iconURL: "anthropic"
      dropParams: ["stop"]

    # xAI — Grok family
    - name: "xAI"
      apiKey: "${GPTSAPI_KEY}"
      baseURL: "https://api.gptsapi.net/v1"
      models:
        default:
          - "grok-4.3"
          - "grok-4-1-fast-non-reasoning"
          - "grok-4.20-beta-0309-reasoning"
          - "grok-4.20-beta-0309-non-reasoning"
          - "grok-4.20-multi-agent-beta-0309"
        fetch: false
      titleConvo: true
      titleModel: "gemini-2.5-flash-lite"
      modelDisplayLabel: "xAI"
      iconURL: "xai"
      dropParams: ["stop"]

    # DeepSeek
    - name: "DeepSeek"
      apiKey: "${GPTSAPI_KEY}"
      baseURL: "https://api.gptsapi.net/v1"
      models:
        default: ["deepseek-v4-pro", "deepseek-v4-flash"]
        fetch: false
      titleConvo: true
      titleModel: "gemini-2.5-flash-lite"
      modelDisplayLabel: "DeepSeek"
      dropParams: ["stop"]

    # GLM (Zhipu)
    - name: "GLM"
      apiKey: "${GPTSAPI_KEY}"
      baseURL: "https://api.gptsapi.net/v1"
      models:
        default: ["glm-5.2", "glm-5-turbo"]
        fetch: false
      titleConvo: true
      titleModel: "gemini-2.5-flash-lite"
      modelDisplayLabel: "GLM"
      dropParams: ["stop"]

    # Kimi (Moonshot)
    - name: "Kimi"
      apiKey: "${GPTSAPI_KEY}"
      baseURL: "https://api.gptsapi.net/v1"
      models:
        default: ["kimi-k2.6"]
        fetch: false
      titleConvo: true
      titleModel: "gemini-2.5-flash-lite"
      modelDisplayLabel: "Kimi"
      dropParams: ["stop"]

    # MiniMax
    - name: "MiniMax"
      apiKey: "${GPTSAPI_KEY}"
      baseURL: "https://api.gptsapi.net/v1"
      models:
        default: ["MiniMax-M3"]
        fetch: false
      titleConvo: true
      titleModel: "gemini-2.5-flash-lite"
      modelDisplayLabel: "MiniMax"
      dropParams: ["stop"]

# Curated model cards (use.ai-style). enforce: only these show in the selector.
modelSpecs:
  enforce: true
  prioritize: true
  list:
    # ---- Gemini ----
    - name: "gemini-2.5-flash"
      label: "Gemini 2.5 Flash"
      default: true
      group: "Gemini"
      iconURL: "google"
      description: "Fast & efficient"
      preset: { endpoint: "Gemini", model: "gemini-2.5-flash" }
    - name: "gemini-3.1-pro-preview"
      label: "Gemini 3.1 Pro"
      group: "Gemini"
      iconURL: "google"
      preset: { endpoint: "Gemini", model: "gemini-3.1-pro-preview" }
    - name: "gemini-3-flash-preview"
      label: "Gemini 3 Flash"
      group: "Gemini"
      iconURL: "google"
      preset: { endpoint: "Gemini", model: "gemini-3-flash-preview" }
    - name: "gemini-2.5-flash-lite"
      label: "Gemini 2.5 Flash Lite"
      group: "Gemini"
      iconURL: "google"
      preset: { endpoint: "Gemini", model: "gemini-2.5-flash-lite" }
    # ---- OpenAI ----
